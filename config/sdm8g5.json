{
  "meta": {
    "name": "12X",
    "author": "12X"
  },
  "modules": {
    "switcher": {
      "switchInode": "/sdcard/Android/yc/uperf/cur_powermode.txt",
      "perapp": "/sdcard/Android/yc/uperf/perapp_powermode.txt",
      "hintDuration": {
        "idle": 0.0,
        "touch": 1.0,
        "trigger": 0.022,
        "gesture": 0.035,
        "switch": 0.24,
        "junk": 0.025
      }
    },
    "atrace": {
      "enable": false
    },
    "log": {
      "level": "info"
    },
    "input": {
      "enable": true,
      "swipeThd": 0.03,
      "gestureThdX": 0.03,
      "gestureThdY": 0.03,
      "gestureDelayTime": 0.8,
      "holdEnterTime": 0.7
    },
    "sfanalysis": {
      "enable": true,
      "renderIdleSlackTime": 0.16
    },
    "cpu": {
      "enable": true,
      "powerModel": [
        {
          "efficiency": 340,
          "nr": 6,
          "typicalPower": 2.4,
          "typicalFreq": 2.5,
          "sweetFreq": 1.2,
          "plainFreq": 0.9,
          "freeFreq": 0.7
        },
        {
          "efficiency": 470,
          "nr": 2,
          "typicalPower": 3.6,
          "typicalFreq": 2.8,
          "sweetFreq": 1.4,
          "plainFreq": 1.1,
          "freeFreq": 0.9
        }
      ]
    },
    "sysfs": {
      "enable": true,
      "knob": {
        "cpusetTa": "/dev/cpuset/top-app/cpus",
        "cpusetFg": "/dev/cpuset/foreground/cpus",
        "cpusetBg": "/dev/cpuset/background/cpus",
        "cpusetSysBg": "/dev/cpuset/system-background/cpus",
        "cpusetRe": "/dev/cpuset/restricted/cpus",
        "gpuMinFreq": "/sys/class/kgsl/kgsl-3d0/devfreq/min_freq",
        "gpuMaxFreq": "/sys/class/kgsl/kgsl-3d0/devfreq/max_freq"
      }
    },
    "sched": {
      "enable": true,
      "cpumask": {
        "all": [0, 1, 2, 3, 4, 5, 6, 7],
        "c0": [0, 1, 2, 3, 4, 5],
        "c1": [6],
        "c2": [7],
        "c12": [6, 7]
      },
      "affinity": {
        "auto": {"bg": "", "fg": "", "idle": "", "touch": "", "boost": ""},
        "norm": {"bg": "", "fg": "c0", "idle": "c0", "touch": "c1", "boost": "c12"},
        "bg": {"bg": "", "fg": "c0", "idle": "c0", "touch": "c0", "boost": "c0"},
        "ui": {"bg": "", "fg": "c1", "idle": "c0", "touch": "c1", "boost": "c12"},
        "crit": {"bg": "", "fg": "c1", "idle": "c1", "touch": "c12", "boost": "c2"},
        "gtcoop": {"bg": "", "fg": "c1", "idle": "c1", "touch": "c12", "boost": "c12"},
        "gtmain": {"bg": "", "fg": "c1", "idle": "c1", "touch": "c12", "boost": "c2"}
      },
      "prio": {
        "auto": {"bg": 0, "fg": 0, "idle": 0, "touch": 0, "boost": 0},
        "bg": {"bg": -3, "fg": 139, "idle": 139, "touch": 139, "boost": 139},
        "norm": {"bg": -1, "fg": -1, "idle": 118, "touch": 114, "boost": 110},
        "coop": {"bg": -3, "fg": 122, "idle": 120, "touch": 116, "boost": 112},
        "ui": {"bg": -3, "fg": 116, "idle": 108, "touch": 104, "boost": 102},
        "rtusr": {"bg": 0, "fg": 0, "idle": 0, "touch": 0, "boost": 0},
        "rtsys": {"bg": 0, "fg": 0, "idle": 0, "touch": 0, "boost": 0}
      },
      "rules": [
        {
          "name": "Video Playback Apps",
          "regex": "^(tv\\.danmaku\\.bili|com\\.google\\.android\\.youtube|com\\.qiyi\\.video|com\\.tencent\\.qqlive|com\\.youku\\.phone|com\\.netflix\\.mediaclient|com\\.ss\\.android\\.ugc\\.aweme)(:|$)",
          "pinned": false,
          "rules": [
            {"k": "/MAIN_THREAD/", "ac": "norm", "pc": "norm"},
            {"k": "^(RenderThread|GLThread|Compositor|CrRendererMain|CrGpuMain)", "ac": "norm", "pc": "coop"},
            {"k": "^(ExoPlayer|MediaCodec|FFmpeg|AudioTrack|Player)", "ac": "bg", "pc": "bg"},
            {"k": ".", "ac": "norm", "pc": "auto"}
          ]
        },
        {
          "name": "Default rule",
          "regex": ".",
          "pinned": false,
          "rules": [
            {"k": "/MAIN_THREAD/", "ac": "ui", "pc": "ui"},
            {"k": "^(UnityMain|RenderThread |GameThread)", "ac": "gtmain", "pc": "auto"},
            {"k": "^(Unity|Worker Thread|TaskGraph|RHIThread|GLThread|Thread-|Job.Worker)", "ac": "gtcoop", "pc": "auto"},
            {"k": ".", "ac": "norm", "pc": "auto"}
          ]
        }
      ]
    }
  },
  "initials": {
    "cpu": {
